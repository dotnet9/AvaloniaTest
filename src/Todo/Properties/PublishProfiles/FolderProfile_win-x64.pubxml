<Project>
  <Import Project="$(MSBuildThisFileDirectory)Publish.Project.pubxml" />
  <Import Project="$(MSBuildThisFileDirectory)..\..\..\..\Publish.Common.pubxml" />
  <PropertyGroup>
    <PublishDir>..\..\publish\win-x64\Todo\</PublishDir>
    <TargetFramework>net11.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishAot>true</PublishAot>
  </PropertyGroup>
</Project>
